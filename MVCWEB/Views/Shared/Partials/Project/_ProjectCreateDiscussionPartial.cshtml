@using MVCWEB.ViewModel.ForProject
@model ProjectCreateDiscussionViewModel

<div class="container py-5" style="max-width: 680px;">

    <div class="mb-4">
        <h4 class="fw-bold mb-1">Start a Discussion</h4>
        <p class="text-muted small mb-0">Share ideas, ask questions, or post updates with your project team.</p>
    </div>

    <div class="card border shadow-sm rounded-3">
        <div class="card-body p-4">

            @using (Html.BeginForm("CreateDiscussion", "Project", FormMethod.Post))
            {
                @Html.AntiForgeryToken()

                @* Summary validation errors *@
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger py-2 px-3 mb-4 small">
                        @Html.ValidationSummary(false, "", new { @class = "mb-0" })
                    </div>
                }

                @* Title *@
                <div class="mb-3">
                    <label asp-for="Title" class="form-label fw-semibold">
                        @Html.DisplayNameFor(m => m.Title)
                        <span class="text-danger">*</span>
                    </label>
                    @Html.TextBoxFor(m => m.Title, new {
                        @class = "form-control" + (ViewData.ModelState["Title"]?.Errors.Count > 0 ? " is-invalid" : ""),
                        placeholder = "e.g. API integration plan, Sprint review notes...",
                        maxlength = "100"
                    })
                    @Html.ValidationMessageFor(m => m.Title, "", new { @class = "invalid-feedback" })
                </div>

                @* Description *@
                <div class="mb-4">
                    <label asp-for="Description" class="form-label fw-semibold">
                        @Html.DisplayNameFor(m => m.Description)
                        <span class="text-danger">*</span>
                    </label>
                    @Html.TextAreaFor(m => m.Description, 6, 0, new {
                        @class = "form-control" + (ViewData.ModelState["Description"]?.Errors.Count > 0 ? " is-invalid" : ""),
                        placeholder = "Describe what this discussion is about...",
                        maxlength = "2000",
                        id = "descriptionField"
                    })
                    @Html.ValidationMessageFor(m => m.Description, "", new { @class = "invalid-feedback" })
                    <div class="d-flex justify-content-end mt-1">
                        <small class="text-muted" id="charCount">0 / 2000</small>
                    </div>
                </div>

                @* Actions *@
                <div class="d-flex justify-content-end gap-2">
                    <a href="javascript:history.back()" class="btn btn-outline-secondary">Cancel</a>
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="bi bi-chat-left-text me-1"></i> Post Discussion
                    </button>
                </div>
            }

        </div>
    </div>
</div>

<script>
    // Live character counter for description
    const field = document.getElementById('descriptionField');
    const counter = document.getElementById('charCount');

    if (field && counter) {
        const update = () => {
            const len = field.value.length;
            counter.textContent = `${len} / 2000`;
            counter.classList.toggle('text-danger', len >= 1900);
        };
        field.addEventListener('input', update);
        update(); // init on load (for validation re-render)
    }
</script>