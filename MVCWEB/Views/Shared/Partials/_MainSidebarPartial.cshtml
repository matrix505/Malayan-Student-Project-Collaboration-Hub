@{
}


<div class="sidebar">

    <div class="navbar-toggler">
        <i class="bx bx-menu-close"></i>
    </div>
    <div class="sidebar-profile">
    </div>
    <ul class="sidebar-nav flex-grow-1">

        <li class="sidenav-item">
            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">
                <i class="bx bx-user-circle"></i>
                <span class="links_name">Profile</span>
            </a>
        </li>

        <li class="sidenav-item">
            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">
                <i class="bx bx-folder"></i>
                <span class="links_name">My Projects</span>
            </a>
        </li>

        <li class="sidenav-item">
            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">
                <i class="bx bx-folder-check"></i>
                <span class="links_name">Joined Projects</span>
            </a>
        </li>


        <li class="sidenav-item">
            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">
                <i class="bx bx-folder-search"></i>
                <span class="links_name">Browse Projects</span>
            </a>
        </li>

        <li class="sidenav-item">
            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">
                <i class="bx bx-folder-plus"></i>
                <span class="links_name">Create Project</span>
            </a>
        </li>

        <li class="sidenav-item">
            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">
                <i class="bx bx-envelope"></i>
                <span class="links_name">Join Requests</span>
            </a>
        </li>

    </ul>
</div>

@section Scripts {
        <script type="text/javascript">
            document.addEventListener("DOMContentLoaded", function() {
            const sidebar = document.querySelector(".sidebar");
            const toggler = document.querySelector(".navbar-toggler");

            toggler.addEventListener("click", () => {
                sidebar.classList.toggle("collapsed");


                const icon = toggler.querySelector("i");
                if (sidebar.classList.contains("collapsed")) {
                    icon.classList.replace("bx-menu-close", "bx-menu");
                } else {
                    icon.classList.replace("bx-menu", "bx-menu-close");
                }
            });
        });
        </script>
}
@section PageStyles {
   
}