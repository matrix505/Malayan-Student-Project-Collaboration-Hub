@using MVCWEB.ViewModel.Collab
@model CollabViewModel
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}

<div class="modal-header">
    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
</div>
<div class="modal-body">
    <div class="overview section">
        <h4 class="">@Model.Project.Title</h4>
        <p class="description">@Model.Project.Description</p>
        <p class="owner">@Model.Project.OwnerName</p>
        <span class="status">@Model.Project.Status</span>
    </div>
    <div class="categories section">

    </div>
    <div class="team-members section">
        @foreach(var member in Model.Members)
        {
            if(member.User_id == Model.Project.Owner_id)
            {
                <p>@member.Email [owner]</p>
                continue;
            }
            <p>@member.Email</p>
        }
    </div>
</div>

